# Ollama Monitoring CLI Configuration

# Ollama API URL (Default: http://localhost:11434)
OLLAMA_API_URL=http://localhost:11434

# Ollama API Key (If applicable/needed for proxies)
OLLAMA_API_KEY=

# Custom Log Directory Path (Optional)
# If left empty, the application will use the default system paths:
# MacOS/Linux: ~/.ollama/logs/
# Windows: %LOCALAPPDATA%\Ollama\
OLLAMA_LOG_DIR=
